PORT=3000
MONGO_URI=mongodb://localhost:27017/social_pulse
NODE_ENV=development

CORS_ORIGIN=http://localhost:5173
# can have multiple CORS origins, separated by comma

ACCESS_SECRET=your_super_secret_key
ACCESS_EXPIRY=15m

REFRESH_SECRET=another_super_secret_key
REFRESH_EXPIRY=7d

# Use this command to generate a random secret key for JWT signing
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Set the maximum number of active sessions per user. This limits the number of devices a user can be logged in from simultaneously.
MAX_ACTIVE_SESSIONS=no_of_sessions_allowed_per_user

# Cloudinary configuration for image uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=XXXXXXXXXXXX
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxx
